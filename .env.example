# Strava API — https://www.strava.com/settings/api
STRAVA_CLIENT_ID=your_client_id_here
STRAVA_CLIENT_SECRET=your_client_secret_here

# Supabase — https://supabase.com (optional, for activity caching)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here

# Route Builder — https://openrouteservice.org (optional, free tier)
# Needed for the Route Builder feature (generates GPX loops on real roads).
ORS_API_KEY=your_openrouteservice_key_here

# Restrict the AI Coach / Route Builder proxies to your own Strava athlete id
# (optional but recommended so only you can spend your API quotas).
OWNER_ATHLETE_ID=your_strava_athlete_id
